# ============================================================
# GitOps Landing Zone - Environment Template
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to Git — it is in .gitignore.
#
# Generate strong passwords with:  openssl rand -base64 24
# ============================================================

# === Network ===
DOCKER_NETWORK=gitops
K3D_CLUSTER_NAME=gitops-local
METALLB_IP_START=172.20.0.100
METALLB_IP_END=172.20.0.150
BASE_IP=172.20.0.100
DOMAIN_SUFFIX=local

# === Gitea ===
GITEA_ADMIN_USER=gitea_admin
GITEA_ADMIN_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_24
GITEA_ADMIN_EMAIL=admin@local.dev
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_24
GITEA_DB_NAME=gitea
GITEA_RUNNER_TOKEN=CHANGE_ME_generated_by_gitea_after_first_boot
GITEA_ORG=platform
GITEA_REPO=gitops-infra
GITEA_URL=http://gitea:3000
GITEA_EXTERNAL_URL=http://gitea.local:3000

# === ArgoCD ===
ARGOCD_ADMIN_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_24
ARGOCD_HOST=argocd.local

# === Keycloak ===
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_24
KEYCLOAK_HOST=keycloak.local
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_24
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_REALM=gitops

# === OIDC Client Secrets ===
# Generate with: openssl rand -hex 24
OIDC_GITEA_CLIENT_ID=gitea
OIDC_GITEA_CLIENT_SECRET=CHANGE_ME_openssl_rand_hex_24
OIDC_ARGOCD_CLIENT_ID=argocd
OIDC_ARGOCD_CLIENT_SECRET=CHANGE_ME_openssl_rand_hex_24

# === Vaultwarden ===
# Generate with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=CHANGE_ME_openssl_rand_base64_48

# === Grafana ===
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_24

# === Derived URLs (do not edit) ===
ARGOCD_URL=http://argocd.local
KEYCLOAK_URL=http://keycloak.local
KEYCLOAK_INTERNAL_URL=http://keycloak.local
