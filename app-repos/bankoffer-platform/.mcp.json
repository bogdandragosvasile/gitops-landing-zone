{
  "mcpServers": {
    "playwright": {
      "command": "playwright-mcp",
      "args": [
        "--cdp-endpoint", "http://127.0.0.1:9222",
        "--viewport-size", "1280x720",
        "--headless"
      ]
    },
    "lightpanda": {
      "command": "lightpanda",
      "args": ["mcp"]
    }
  }
}
